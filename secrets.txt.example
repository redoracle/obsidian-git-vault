# Playwright E2E tests may require access to private Git repositories.

# Playwright E2E test secrets (local only) — do NOT commit
#
# These are example placeholders used only by the local Playwright E2E tests.
# Replace values with your local tokens if you intend to run the tests.

## This file is intended to store the necessary credentials for those tests.
## Do not commit this file to version control, as it contains sensitive information.

# GitLab
# GitLab repo URL used by E2E tests
gitlab API - repo: https://gitlab.com/redoracle/obsidian-test-vault.git
# GitLab personal access token (placeholder)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub
# GitHub repo URL used by E2E tests
github API - repo: https://github.com/redoracle/obsidian-test-vault.git
# GitHub personal access token (placeholder)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Gitea
# Gitea repo URL used by E2E tests
gitea API - repo: https://gitea.com/redoracle/obsidian-test-vault.git
# Gitea access token (placeholder). Either use `GITEA_TOKEN=...` or place the token on the
# following line after a line that mentions "gitea" (the test helper supports both formats).
GITEA_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Git (generic)
# Repo used for generic `git` provider tests
git - repo: https://github.com/redoracle/obsidian-test-vault.git

### cp secrets.txt.example secrets.txt
### then edit secrets.txt and fill real tokens before running Playwright
