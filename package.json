{
    "name": "git-vault",
    "version": "1.0",
    "description": "Hybrid Git + GitHub API sync for Obsidian with desktop power features and mobile-first reliability",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs dev",
        "build": "node esbuild.config.mjs production",
        "release": "standard-version",
        "lint": "eslint src",
        "format": "prettier --check src",
        "tsc": "tsc --noEmit",
        "svelte": "svelte-check",
        "all": "pnpm run tsc && pnpm run svelte && pnpm run format && pnpm run lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test"
    },
    "keywords": [],
    "author": "RedOracle",
    "license": "MIT",
    "standard-version": {
        "t": ""
    },
    "engines": {
        "node": ">=18",
        "pnpm": ">=9"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@types/debug": "^4.1.13",
        "@types/deep-equal": "^1.0.4",
        "@types/diff": "^8.0.0",
        "@types/diff3": "^0.0.2",
        "@types/node": "^22.19.17",
        "@typescript-eslint/parser": "8.58.2",
        "@vitest/coverage-v8": "^4.1.4",
        "esbuild": "^0.28.0",
        "esbuild-svelte": "^0.8.2",
        "eslint": "^9.39.4",
        "eslint-plugin-svelte": "^3.17.0",
        "moment": "^2.30.1",
        "obsidian": "^1.12.3",
        "prettier": "3.3.2",
        "prettier-plugin-svelte": "^3.5.1",
        "scss": "^0.2.4",
        "standard-version": "^9.5.0",
        "svelte-check": "^4.4.6",
        "svelte-eslint-parser": "^0.43.0",
        "svelte-preprocess": "^6.0.3",
        "tslib": "^2.8.1",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4"
    },
    "dependencies": {
        "@codemirror/commands": "^6.10.3",
        "@codemirror/merge": "^6.12.1",
        "@codemirror/search": "^6.6.0",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.41.0",
        "buffer": "^6.0.3",
        "codemirror": "^6.0.2",
        "css-color-converter": "^2.0.0",
        "debug": "^4.4.3",
        "deep-equal": "^2.2.3",
        "diff": "^8.0.4",
        "diff2html": "^3.4.56",
        "diff3": "^0.0.4",
        "isomorphic-git": "^1.37.5",
        "js-sha256": "^0.11.1",
        "simple-git": "^3.36.0",
        "supports-color": "^9.4.0",
        "svelte": "^5.55.4"
    },
    "moduleFileExtensions": [
        "js",
        "ts",
        "svelte"
    ]
}
